import SwiftUI

struct LeftRightGameView: View {
    @EnvironmentObject var engine: PetEngine
    let onDone: () -> Void
    private let totalRounds = 5

    @State private var round = 1
    @State private var score = 0
    @State private var revealed: Int?
    @State private var rewarded = false

    private var frame: [String] {
        guard let revealed else {
            return TamaSpriteCatalog.frame(persona: engine.pet.persona,
                                           mood: .content,
                                           phase: engine.tick,
                                           cosmetics: engine.pet.cosmetics)
        }
        return TamaSpriteCatalog.directionFrame(left: revealed == 0)
    }

    var body: some View {
        VStack(spacing: 6) {
            Text("Раунд \(min(round, totalRounds))/\(totalRounds)  ⭐️ \(score)")
                .font(.system(size: 11, weight: .semibold, design: .rounded))
            PixelSpriteView(grid: frame).frame(width: 78, height: 78)

            if round <= totalRounds {
                HStack(spacing: 10) {
                    guessButton("⬅️", 0)
                    guessButton("➡️", 1)
                }
                .disabled(revealed != nil)
            } else {
                Button("Готово") {
                    rewarded = true
                    engine.rewardGame(score: score)
                    onDone()
                }.tint(.green)
            }
        }
        // Свайп шита не должен сжигать заработанные очки
        .onDisappear {
            if !rewarded && score > 0 { engine.rewardGame(score: score) }
        }
    }

    private func guessButton(_ emoji: String, _ direction: Int) -> some View {
        Button { guess(direction) } label: {
            Text(emoji).font(.system(size: 22)).frame(width: 52, height: 38)
        }
    }

    private func guess(_ value: Int) {
        let direction = Int.random(in: 0...1)
        revealed = direction
        if direction == value { score += 1 }
        // DispatchQueue.main.asyncAfter здесь не проходит Swift 6 strict
        // concurrency: @Sendable-замыкание захватывает MainActor-состояние.
        Task { @MainActor in
            try? await Task.sleep(nanoseconds: 800_000_000)
            revealed = nil
            round += 1
        }
    }
}
